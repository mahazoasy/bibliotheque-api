          "Books"
        ]
      },
      "post": {
        "operationId": "BooksController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBookDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Livre créé"
          },
          "401": {
            "description": "Non authentifié"
          },
          "422": {
            "description": "Validation échouée"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Ajouter un livre",
        "tags": [
          "Books"
        ]
      }
    },
