        ]
      },
      "delete": {
        "operationId": "BooksController_remove",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Livre supprimé"
          },
          "401": {
            "description": "Non authentifié"
          },
          "404": {
            "description": "Livre non trouvé"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Supprimer un livre",
        "tags": [
          "Books"
        ]
      }
    },
    "/api/v1/borrows": {
      "get": {
        "operationId": "BorrowsController_findAllActive",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Liste obtenue"
          },
          "401": {
            "description": "Non authentifié"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Liste tous les emprunts en cours",
        "tags": [
          "Borrows"
        ]
      },
      "post": {
        "operationId": "BorrowsController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBorrowDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Emprunt créé"
