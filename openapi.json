  "info": {
    "title": "API Bibliothèque",
    "description": "API REST de gestion de bibliothèque — Cours 2026",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "http://localhost:3000/api/v1",
      "description": "Développement"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {}
      },
      "CreateAuthorDto": {
        "type": "object",
        "properties": {
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "nationality": {
            "type": "string"
          }
        },
        "required": [
          "first_name",
          "last_name"
        ]
      },
      "UpdateAuthorDto": {
        "type": "object",
        "properties": {
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "nationality": {
            "type": "string"
          }
        }
      },
      "CreateBookDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "isbn": {
            "type": "string"
          },
          "year": {
            "type": "number"
          },
          "available": {
            "type": "boolean",
            "default": true
          },
          "author_id": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "isbn",
          "year",
          "available",
          "author_id"
        ]
      },
      "UpdateBookDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "isbn": {
            "type": "string"
          },
          "year": {
            "type": "number"
          },
          "available": {
            "type": "boolean",
            "default": true
          },
          "author_id": {
            "type": "string"
          }
        }
      },
      "CreateBorrowDto": {
        "type": "object",
        "properties": {
          "user_name": {
            "type": "string"
          },
          "book_id": {
            "type": "string"
          }
        },
        "required": [
          "user_name",
          "book_id"
        ]
      }
    }
  }
}